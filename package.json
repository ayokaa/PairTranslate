{
	"name": "pair-translate",
	"description": "A browser extension for translating text on webpages.",
	"private": true,
	"version": "2.5.0",
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"test": "bun test",
		"dev:firefox": "wxt -b firefox",
		"build": "wxt build",
		"build:firefox": "wxt build -b firefox",
		"zip": "wxt zip",
		"zip:firefox": "wxt zip -b firefox",
		"lint": "biome check",
		"lint:fix": "biome check --write",
		"lint:fix:unsafe": "biome check --write --unsafe",
		"compile": "wxt prepare && tsc --noEmit",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@google/genai": "^1.52.0",
		"@solid-primitives/deep": "^0.3.5",
		"@solid-primitives/refs": "^1.1.3",
		"@solidjs/router": "^0.16.1",
		"@wxt-dev/i18n": "^0.2.5",
		"clsx": "^2.1.1",
		"katex": "^0.16.45",
		"lucide-solid": "^1.14.0",
		"mathml-to-latex": "^1.5.0",
		"monaco-editor-core": "^0.55.1",
		"motion": "^12.38.0",
		"openai": "^6.37.0",
		"reflect-metadata": "^0.2.2",
		"remark-math": "^6.0.0",
		"remark-parse": "^11.0.0",
		"solid-js": "^1.9.12",
		"solid-router": "^0.3.3",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tinyld": "^1.3.4",
		"tldts": "^7.4.3",
		"unified": "^11.0.5",
		"uuid": "^14.0.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.13",
		"@types/mdast": "^4.0.4",
		"@wxt-dev/auto-icons": "^1.1.1",
		"@wxt-dev/module-solid": "^1.1.4",
		"daisyui": "^5.5.19",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"wxt": "^0.20.25"
	}
}
